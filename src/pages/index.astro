---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-content">
      <span class="hero-tag">Learning in Public</span>
      <h1>From Zero to <span class="accent">Options Trader</span></h1>
      <p>Following the journey of learning options trading from scratch — every win, loss, and lesson documented.</p>
    </div>
  </section>

  <main class="main-content">

    <!-- OPEN POSITIONS -->
    <div class="positions-header">
      <h2 class="section-title" style="margin-bottom:0;">Open Positions</h2>
      <span class="positions-account">Tastytrade · $1K Account</span>
    </div>
    <div class="positions-table">
      <table>
        <thead>
          <tr>
            <th>Position</th>
            <th class="right">Last</th>
            <th class="right">P/L</th>
            <th class="right">IVR</th>
            <th class="right">DTE</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>
              <div class="ticker-cell">
                <span class="ticker-symbol">PLTR</span>
                <span class="ticker-type type-put">PUT</span>
                <span class="ticker-strike">$120 · Jul 17</span>
              </div>
            </td>
            <td class="right" style="color:var(--text-primary);font-weight:600;">$143.05</td>
            <td class="right pl-positive">+$132.00</td>
            <td class="right text-dim">23.5</td>
            <td class="right text-dim">110d</td>
          </tr>
          <tr>
            <td colspan="5" class="empty-row">Next position goes here...</td>
          </tr>
        </tbody>
      </table>
      <div class="positions-footer">
        <span class="pf-label">Total P/L</span>
        <span class="pf-value pl-positive">+$132.00</span>
      </div>
    </div>

    <!-- JOURNEY CHART -->
    <div class="journey-header" style="margin-top:40px;">
      <h2 class="section-title" style="margin-bottom:0;">The Journey So Far</h2>
      <span class="journey-range">Started March 26, 2026</span>
    </div>
    <div class="chart-container" id="chartContainer">
      <div class="y-labels">
        <span class="y-label">Advanced</span>
        <span class="y-label">Intermediate</span>
        <span class="y-label">Foundations</span>
        <span class="y-label">Zero</span>
      </div>

      <svg class="journey-chart" id="journeyChart" viewBox="0 0 900 380" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#58a6ff"/>
            <stop offset="100%" stop-color="#3fb950"/>
          </linearGradient>
          <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#58a6ff" stop-opacity="0.12"/>
            <stop offset="100%" stop-color="#58a6ff" stop-opacity="0"/>
          </linearGradient>
        </defs>

        <!-- Grid lines -->
        <line x1="60" y1="30" x2="880" y2="30" stroke="#1a2030" stroke-width="0.5"/>
        <line x1="60" y1="90" x2="880" y2="90" stroke="#1a2030" stroke-width="0.5"/>
        <line x1="60" y1="150" x2="880" y2="150" stroke="#1a2030" stroke-width="0.5"/>
        <line x1="60" y1="210" x2="880" y2="210" stroke="#1a2030" stroke-width="0.5"/>

        <!-- 50-period MA (orange, lagging) -->
        <path d="M80,230 C150,228 200,222 280,218 C360,214 400,210 440,200 C480,192 520,186 560,178 C600,172 650,165 700,158 C740,153 780,148 820,142 L860,138"
              stroke="#d29922" stroke-width="1.5" fill="none" stroke-dasharray="6,4" opacity="0.5"/>

        <!-- 20-period MA (blue, responsive) -->
        <path d="M80,225 C130,220 180,215 230,207 C280,200 320,195 380,188 C420,182 460,176 510,168 C560,162 610,155 660,145 C710,138 750,130 800,120 L860,112"
              stroke="#58a6ff" stroke-width="1.5" fill="none" stroke-dasharray="4,3" opacity="0.4"/>

        <!-- Area fill -->
        <path d="M80,230 L200,200 L340,180 L440,168 L540,152 L650,136 L760,116 L850,98 L850,240 L80,240 Z" fill="url(#areaGrad)"/>

        <!-- Main journey line -->
        <path d="M80,230 L140,218 L200,200 L260,192 L340,180 L390,174 L440,168 L490,160 L540,152 L590,144 L650,136 L710,126 L760,116 L810,106 L850,98"
              stroke="url(#lineGrad)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>

        <!-- Volume separator -->
        <line x1="60" y1="255" x2="880" y2="255" stroke="#30363d" stroke-width="0.5"/>

        <!-- VOLUME BARS -->
        <rect x="72" y="296" width="14" height="24" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="92" y="290" width="14" height="30" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="112" y="300" width="14" height="20" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="132" y="286" width="14" height="34" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="152" y="294" width="14" height="26" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="172" y="302" width="14" height="18" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="192" y="288" width="14" height="32" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="222" y="298" width="14" height="22" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="242" y="304" width="14" height="16" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="262" y="292" width="14" height="28" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="282" y="296" width="14" height="24" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="312" y="302" width="14" height="18" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="332" y="284" width="14" height="36" fill="#3fb950" rx="1" opacity="0.8"/>
        <rect x="352" y="290" width="14" height="30" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="372" y="300" width="14" height="20" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="392" y="294" width="14" height="26" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="412" y="288" width="14" height="32" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="432" y="306" width="14" height="14" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="452" y="298" width="14" height="22" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="492" y="308" width="14" height="12" fill="#f85149" rx="1" opacity="0.4"/>
        <rect x="512" y="310" width="14" height="10" fill="#f85149" rx="1" opacity="0.3"/>
        <rect x="552" y="296" width="14" height="24" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="572" y="290" width="14" height="30" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="592" y="284" width="14" height="36" fill="#3fb950" rx="1" opacity="0.8"/>
        <rect x="612" y="300" width="14" height="20" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="632" y="278" width="14" height="42" fill="#3fb950" rx="1" opacity="0.9"/>
        <rect x="652" y="290" width="14" height="30" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="672" y="296" width="14" height="24" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="692" y="286" width="14" height="34" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="712" y="280" width="14" height="40" fill="#3fb950" rx="1" opacity="0.85"/>
        <rect x="732" y="294" width="14" height="26" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="752" y="302" width="14" height="18" fill="#f85149" rx="1" opacity="0.6"/>
        <rect x="772" y="288" width="14" height="32" fill="#3fb950" rx="1" opacity="0.7"/>
        <rect x="792" y="282" width="14" height="38" fill="#3fb950" rx="1" opacity="0.8"/>
        <rect x="812" y="276" width="14" height="44" fill="#3fb950" rx="1" opacity="0.9"/>
        <rect x="832" y="270" width="14" height="50" fill="#3fb950" rx="1" opacity="1"/>

        <!-- Volume average line -->
        <path d="M80,306 L200,300 L340,298 L440,296 L540,302 L600,294 L700,290 L800,286 L850,282"
              stroke="#d29922" stroke-width="1" fill="none" opacity="0.4"/>

        <text x="65" y="268" fill="#484f58" font-size="8" text-anchor="start">VOL</text>

        <!-- X-axis dates -->
        <text x="80" y="340" fill="#484f58" font-size="11" text-anchor="middle">3/26</text>
        <text x="280" y="340" fill="#484f58" font-size="11" text-anchor="middle">3/26</text>
        <text x="440" y="340" fill="#484f58" font-size="11" text-anchor="middle">3/27</text>
        <text x="510" y="340" fill="#484f58" font-size="11" text-anchor="middle">3/28</text>
        <text x="700" y="340" fill="#484f58" font-size="11" text-anchor="middle">3/29</text>
        <text x="850" y="340" fill="#484f58" font-size="11" text-anchor="middle">Now</text>

        <!-- Milestone dots -->
        <circle cx="80" cy="230" r="5" fill="var(--bg-primary)" stroke="#d29922" stroke-width="2" class="milestone" data-idx="0" style="cursor:pointer"/>
        <circle cx="200" cy="200" r="5" fill="var(--bg-primary)" stroke="#bc8cff" stroke-width="2" class="milestone" data-idx="1" style="cursor:pointer"/>
        <circle cx="340" cy="180" r="7" fill="var(--bg-primary)" stroke="#58a6ff" stroke-width="2.5" class="milestone" data-idx="2" style="cursor:pointer"/>
        <circle cx="440" cy="168" r="6" fill="var(--bg-primary)" stroke="#3fb950" stroke-width="2.5" class="milestone" data-idx="3" style="cursor:pointer"/>
        <circle cx="540" cy="152" r="5" fill="var(--bg-primary)" stroke="#58a6ff" stroke-width="2" class="milestone" data-idx="4" style="cursor:pointer"/>
        <circle cx="650" cy="136" r="5" fill="var(--bg-primary)" stroke="#bc8cff" stroke-width="2" class="milestone" data-idx="5" style="cursor:pointer"/>
        <circle cx="760" cy="116" r="5" fill="var(--bg-primary)" stroke="#3fb950" stroke-width="2" class="milestone" data-idx="6" style="cursor:pointer"/>
        <circle cx="850" cy="98" r="7" fill="var(--bg-primary)" stroke="#58a6ff" stroke-width="2.5" class="milestone" data-idx="7" style="cursor:pointer"/>

        <!-- Pulsing glow -->
        <circle cx="850" cy="98" r="12" fill="none" stroke="#3fb950" stroke-width="1" opacity="0.3">
          <animate attributeName="r" values="9;16;9" dur="2s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="0.4;0.1;0.4" dur="2s" repeatCount="indefinite"/>
        </circle>

        <!-- Labels -->
        <text x="80" y="222" fill="#d29922" font-size="8" text-anchor="middle" font-weight="600">DAY 1</text>
        <text x="200" y="192" fill="#bc8cff" font-size="8" text-anchor="middle" font-weight="600">SCREENER</text>
        <text x="340" y="170" fill="#58a6ff" font-size="8" text-anchor="middle" font-weight="600">ED SESSION</text>
        <text x="440" y="160" fill="#3fb950" font-size="8" text-anchor="middle" font-weight="600">1ST TRADE</text>
        <text x="540" y="144" fill="#58a6ff" font-size="8" text-anchor="middle" font-weight="600">RULES</text>
        <text x="650" y="128" fill="#bc8cff" font-size="8" text-anchor="middle" font-weight="600">SITE LIVE</text>
        <text x="760" y="108" fill="#3fb950" font-size="8" text-anchor="middle" font-weight="600">MA SIGNALS</text>
        <text x="850" y="88" fill="#58a6ff" font-size="8" text-anchor="middle" font-weight="600">FULL READ</text>
      </svg>

      <!-- MA Legend -->
      <div class="ma-legend">
        <div class="ma-legend-item"><span class="ma-dot" style="background:#58a6ff;"></span> 20-period</div>
        <div class="ma-legend-item"><span class="ma-dot" style="background:#d29922;"></span> 50-period</div>
        <div class="ma-legend-item"><span class="ma-dot" style="background:linear-gradient(90deg,#58a6ff,#3fb950);"></span> Journey</div>
      </div>

      <div class="milestone-tooltip" id="tooltip"></div>
    </div>

    <!-- TOOLKIT -->
    <h2 class="section-title" style="margin-top:40px;">My Toolkit</h2>
    <div class="toolkit-row">
      <a href="https://tastytrade.com" target="_blank" rel="noopener" class="tool-card">
        <div class="tool-icon" style="background: rgba(232, 63, 64, 0.12);">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="10" cy="9" r="5" fill="#e83f40"/>
            <path d="M10 14 Q10 20 14 22" stroke="#e83f40" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <circle cx="8" cy="7" r="1.5" fill="#ff6b6b" opacity="0.7"/>
          </svg>
        </div>
        <div class="tool-info">
          <div class="tool-name" style="color: #e83f40;">tastytrade</div>
          <div class="tool-role">Trading Platform</div>
        </div>
      </a>
      <a href="https://thinkorswim.com" target="_blank" rel="noopener" class="tool-card">
        <div class="tool-icon" style="background: rgba(0, 166, 237, 0.12);">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <line x1="14" y1="2" x2="14" y2="10" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="14" y1="18" x2="14" y2="26" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="2" y1="14" x2="10" y2="14" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="18" y1="14" x2="26" y2="14" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="5.5" y1="5.5" x2="10.5" y2="10.5" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="17.5" y1="17.5" x2="22.5" y2="22.5" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="22.5" y1="5.5" x2="17.5" y2="10.5" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="10.5" y1="17.5" x2="5.5" y2="22.5" stroke="#00a6ed" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="tool-info">
          <div class="tool-name" style="color: #00a6ed;">thinkorswim</div>
          <div class="tool-role">Charting & Analysis</div>
        </div>
      </a>
      <a href="https://unusualwhales.com" target="_blank" rel="noopener" class="tool-card">
        <div class="tool-icon" style="background: rgba(57, 210, 192, 0.12);">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <ellipse cx="14" cy="17" rx="10" ry="6.5" fill="#39d2c0"/>
            <ellipse cx="14" cy="15" rx="7" ry="4" fill="#2ab5a5"/>
            <circle cx="10" cy="15" r="1.2" fill="#0d1117"/>
            <path d="M7 11 Q10 6 14 9 Q18 6 21 11" stroke="#39d2c0" stroke-width="2" fill="none" stroke-linecap="round"/>
            <path d="M20 18 Q24 16 25 19" stroke="#39d2c0" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="tool-info">
          <div class="tool-name" style="color: #39d2c0;">Unusual Whales</div>
          <div class="tool-role">Options Flow Data</div>
        </div>
      </a>
      <a href="https://go-maz.com" target="_blank" rel="noopener" class="tool-card">
        <div class="tool-icon" style="background: rgba(188, 140, 255, 0.12);">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="10" stroke="#bc8cff" stroke-width="2" fill="none"/>
            <circle cx="14" cy="14" r="4" fill="#bc8cff"/>
            <line x1="14" y1="4" x2="14" y2="8" stroke="#bc8cff" stroke-width="2" stroke-linecap="round"/>
            <line x1="14" y1="20" x2="14" y2="24" stroke="#bc8cff" stroke-width="2" stroke-linecap="round"/>
            <line x1="4" y1="14" x2="8" y2="14" stroke="#bc8cff" stroke-width="2" stroke-linecap="round"/>
            <line x1="20" y1="14" x2="24" y2="14" stroke="#bc8cff" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="tool-info">
          <div class="tool-name" style="color: #bc8cff;">Go Maz</div>
          <div class="tool-role">Screener & Signals</div>
        </div>
      </a>
      <a href="https://claude.ai" target="_blank" rel="noopener" class="tool-card">
        <div class="tool-icon" style="background: rgba(217, 168, 111, 0.12);">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="12" r="8" fill="#d9a86f"/>
            <circle cx="14" cy="12" r="5" fill="#c4884a"/>
            <ellipse cx="14" cy="22" rx="6" ry="3" fill="#d9a86f" opacity="0.4"/>
            <circle cx="11" cy="11" r="1" fill="#0d1117"/>

</style>

<script>
const milestones = [
  {
    tag: "Journal", tagColor: "#d29922", tagBg: "rgba(210,153,34,0.15)",
    title: "Day 1 — The Setup",
    desc: "Account funded on Tastytrade. ThinkorSwim downloaded. First time looking at a real options chain.",
    date: "March 26, 2026",
    link: "/blog/day-1-the-setup"
  },
  {
    tag: "Analysis", tagColor: "#bc8cff", tagBg: "rgba(188,140,255,0.15)",
    title: "Go Maz First Scan",
    desc: "Ran the screener for the first time. AMD, NVDA, BA, RIVN all lit up. Applied Ed's 7 rules.",
    date: "March 26, 2026",
    link: "/blog/go-maz-first-scan"
  },
  {
    tag: "Education", tagColor: "#58a6ff", tagBg: "rgba(88,166,255,0.15)",
    title: "Ed Session — Core Charting",
    desc: "Moving averages, support & resistance, volume, RSI, A/D, delta, IVR. The foundation session.",
    date: "March 26, 2026",
    link: "/education"
  },
  {
    tag: "Trade", tagColor: "#3fb950", tagBg: "rgba(63,185,80,0.15)",
    title: "First Trade — PLTR $120 Put",
    desc: "First ever options trade. 120-day expiration, 20-delta. Real money, real learning.",
    date: "March 26, 2026",
    link: "/blog/first-trade-pltr-put"
  },
  {
    tag: "Education", tagColor: "#58a6ff", tagBg: "rgba(88,166,255,0.15)",
    title: "Go Maz 7 Rules + Vega + Bid/Ask",
    desc: "Deep dive on Ed's scoring system. Vega lesson when IVR jumped from 18.7 to 48.",
    date: "March 27, 2026",
    link: "/education"
  },
  {
    tag: "Build", tagColor: "#bc8cff", tagBg: "rgba(188,140,255,0.15)",
    title: "Site Goes Live",
    desc: "saltwaterbrc.net deployed. Education hub with Black-Scholes, Expected Move, IVR, S&R pages.",
    date: "March 27, 2026",
    link: "/education"
  },
  {
    tag: "Education", tagColor: "#3fb950", tagBg: "rgba(63,185,80,0.15)",
    title: "MA Signals Blog Post",
    desc: "Bullish & bearish stacking, golden cross, death cross, bounce, rejection, squeeze — 7 SVG charts.",
    date: "March 29, 2026",
    link: "/blog/bullish-bearish-signals"
  },
  {
    tag: "Milestone", tagColor: "#58a6ff", tagBg: "rgba(88,166,255,0.15)",
    title: "Full Chart Read — All 5 Indicators",
    desc: "MAs + candles + volume + RSI + A/D on live PLTR. The Trade Confidence Check.",
    date: "March 29, 2026",
    link: "/blog"
  }
];

const dotPositions = [
  { x: 80, y: 230 }, { x: 200, y: 200 }, { x: 340, y: 180 }, { x: 440, y: 168 },
  { x: 540, y: 152 }, { x: 650, y: 136 }, { x: 760, y: 116 }, { x: 850, y: 98 }
];

const tooltip = document.getElementById('tooltip');
const container = document.getElementById('chartContainer');
const svg = document.getElementById('journeyChart');

document.querySelectorAll('.milestone').forEach(dot => {
  dot.addEventListener('mouseenter', () => {
    const idx = parseInt(dot.getAttribute('data-idx'));
    const m = milestones[idx];
    const pos = dotPositions[idx];
    const svgRect = svg.getBoundingClientRect();
    const containerRect = container.getBoundingClientRect();
    const scaleX = svgRect.width / 900;
    const scaleY = svgRect.height / 380;
    const pixelX = (pos.x * scaleX) + (svgRect.left - containerRect.left);
    const pixelY = (pos.y * scaleY) + (svgRect.top - containerRect.top);

    tooltip.innerHTML = `
      <span class="tooltip-tag" style="background:${m.tagBg};color:${m.tagColor}">${m.tag}</span>
      <div class="tooltip-title">${m.title}</div>
      <div class="tooltip-desc">${m.desc}</div>
      <div class="tooltip-date">${m.date}</div>
      <a class="tooltip-link" href="${m.link}">Read more →</a>
    `;
    let left = pixelX + 16;
    if (left + 220 > containerRect.width) left = pixelX - 236;
    let top = pixelY - 80;
    if (top < 0) top = pixelY + 20;
    tooltip.style.left = left + 'px';
    tooltip.style.top = top + 'px';
    tooltip.classList.add('visible');
  });
  dot.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));
  dot.addEventListener('click', () => {
    const idx = parseInt(dot.getAttribute('data-idx'));
    window.location.href = milestones[idx].link;
  });
});
</script>

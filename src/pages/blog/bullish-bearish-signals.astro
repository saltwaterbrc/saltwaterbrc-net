  <line x1="60" y1="270" x2="670" y2="270" stroke="#1e2733" stroke-width="1"/>
  <line x1="60" y1="155" x2="670" y2="155" stroke="#1e2733" stroke-width="0.5" stroke-dasharray="4,4" opacity="0.3"/>

  <!-- 200-day MA (red) — relatively flat -->
  <path d="M80,155 Q180,152 280,150 Q380,150 480,152 Q580,155 650,158" stroke="#f85149" stroke-width="2.5" fill="none" stroke-linecap="round"/>

  <!-- 50-day MA (blue) — comes from above, crosses below -->

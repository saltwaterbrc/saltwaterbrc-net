  <!-- 20-day MA (green) — already below, leading the drop -->
  <path d="M80,115 Q140,135 200,160 Q260,185 320,208 Q400,232 480,248 Q560,258 650,262" stroke="#3fb950" stroke-width="2.5" fill="none" stroke-linecap="round"/>

  <!-- Cross point highlight -->
  <circle cx="330" cy="153" r="18" fill="none" stroke="#f85149" stroke-width="2" stroke-dasharray="4,3"/>
  <circle cx="330" cy="153" r="4" fill="#f85149"/>


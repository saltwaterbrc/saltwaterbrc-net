  <polygon points="330,85 325,92 335,92" fill="#f85149"/>
  <rect x="250" y="58" width="160" height="26" rx="6" fill="rgba(248,81,73,0.12)"/>
  <text x="330" y="76" fill="#f85149" font-size="13" font-family="Inter,sans-serif" font-weight="700" text-anchor="middle">DEATH CROSS</text>

